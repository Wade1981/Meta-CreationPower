{
  "name": "symmetric-finance-system",
  "version": "1.0.0",
  "description": "基于动力学熵原理的对称数智财务系统",
  "author": "启蒙灯塔起源团队",
  "main": "src/main.py",
  "entrypoint": "python src/main.py",
  "requirements": [
    "numpy",
    "pandas",
    "scikit-learn",
    "tensorflow",
    "matplotlib"
  ],
  "environment": {
    "PYTHONPATH": ".",
    "DEBUG": "True"
  },
  "data": {
    "input": "data/input",
    "output": "data/output",
    "logs": "logs"
  },
  "health_check": {
    "command": "python src/main.py",
    "timeout": 30
  },
  "resources": {
    "cpu": "2",
    "memory": "4G",
    "gpu": "optional"
  }
}
