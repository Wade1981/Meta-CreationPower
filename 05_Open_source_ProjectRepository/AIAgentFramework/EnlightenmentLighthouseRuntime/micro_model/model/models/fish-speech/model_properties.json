{
  "model_name": "fish-speech",
  "version": "1.0",
  "description": "Fish Audio Text-to-Speech model",
  "type": "tts",
  "dependencies": {
    "python": "3.12",
    "pip": [
      "torch",
      "torchaudio",
      "transformers",
      "gradio",
      "numpy",
      "scipy",
      "librosa"
    ],
    "system": [
      "portaudio19-dev",
      "libsox-dev",
      "ffmpeg"
    ]
  },
  "resources": {
    "cpu": {
      "min_cores": 4,
      "recommended_cores": 8
    },
    "memory": {
      "min_ram": "16G",
      "recommended_ram": "32G"
    },
    "gpu": {
      "required": false,
      "min_memory": "12G",
      "recommended_memory": "16G",
      "cuda_version": "12.9"
    }
  },
  "environment_variables": {
    "COMPILE": "0",
    "GRADIO_SERVER_PORT": "7860",
    "API_SERVER_PORT": "8080"
  },
  "entry_points": {
    "webui": "python -m fish_speech.webui",
    "api": "python -m fish_speech.api",
    "cli": "python -m fish_speech.cli"
  }
}
